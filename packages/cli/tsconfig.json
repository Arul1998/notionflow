{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@notionflow/core": ["../core/src/index.ts"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*"],
  "references": [{ "path": "../core" }]
}
